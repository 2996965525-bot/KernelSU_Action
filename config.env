CONFIG_ENV=config.env

KERNEL_SOURCE=https://github.com/Xiaomi-pad-6-development/aospa_kernel_xiaomi_pipa
KERNEL_SOURCE_BRANCH=android13-4.19-kona
KERNEL_CONFIG=vendor/pipa_stock_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=false
EXTRA_CMDS:LD=ld.lld
CUSTOM_CMDS:
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

# AOSP
CLANG_BRANCH=master-kernel-build-2022
CLANG_VERSION=r450784e

# GCC
ENABLE_GCC_64=true
ENABLE_GCC_32=true
USE_CUSTOM_GCC64=false
CUSTOM_GCC64_SOURCE=
CUSTOM_GCC64_BRANCH=
CUSTOM_GCC64_BIN=aarch64-linux-gnu-
USE_CUSTOM_GCC32=false
CUSTOM_GCC32_SOURCE=
CUSTOM_GCC32_BRANCH=
CUSTOM_GCC32_BIN=arm-linux-gnueabihf-

# KernelSU flags
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
KSU_EXPECTED_SIZE=
KSU_EXPECTED_HASH=

# Configuration
DISABLE-LTO=false
DISABLE_CC_WERROR=false
ADD_OVERLAYFS_CONFIG=false

# AnyKernel3
USE_CUSTOM_ANYKERNEL3=false
CUSTOM_ANYKERNEL3_SOURCE=
CUSTOM_ANYKERNEL3_BRANCH=

# Ccache
ENABLE_CCACHE=true

# DTBO image
NEED_DTBO=false

# Build boot images
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://raw.githubusercontent.com/xiaoleGun/KernelSU_action/main/boot/boot.img
